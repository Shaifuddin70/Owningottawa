# Serve images only; block script execution
<IfModule mod_mime.c>
  AddType image/jpeg .jpg .jpeg
  AddType image/png .png
  AddType image/webp .webp
  AddType image/gif .gif
</IfModule>
<IfModule mod_php.c>
  php_flag engine off
</IfModule>
<IfModule mod_authz_core.c>
  <FilesMatch "\.(php|phtml|php5|phar)$">
    Require all denied
  </FilesMatch>
</IfModule>
